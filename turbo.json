{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build":{
            "dependsOn": ["^build"],
            "cache": true
        },
        "dev":{
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        },
        "start":{
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        }
    }
}