{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "node",
        "moduleDetection": "force",
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "rootDir": ".",
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@axcelero/utils/*": ["./src/*"]
        },
        "ignoreDeprecations": "6.0"
    }
}