{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "types": [
            "node"
        ],
        "rootDir": ".",
        "outDir": "dist",
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        "paths": {
            "@axcelero/backend/*": [
                "./src/*"
            ]
        },
    },
    "include": ["src"],
    "exclude": [
        "node_modules",
        "dist"
    ]
}